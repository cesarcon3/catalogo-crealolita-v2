---
import type { PublicProduct } from '../services/publicProducts';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;

const unitPrice = product.sale_type === 'docena' ? (product.price / 12).toFixed(2) : null;
---

<article class="group bg-white rounded-2xl overflow-hidden border border-brand-border shadow-sm hover:shadow-xl hover:border-gold-light transition-all duration-300 flex flex-col h-full relative">
  
  {product.is_featured && (
    <span class="absolute top-3 right-3 bg-pink-500 text-white text-xs font-bold px-3 py-1 rounded-full z-20 shadow-sm">
      ⭐ Destacado
    </span>
  )}
  <span class="absolute top-3 left-3 bg-gold text-white text-xs font-bold px-3 py-1 rounded-full z-20 shadow-sm capitalize">
    {product.sale_type === 'mixto' ? 'Docena / Detal' : `Por ${product.sale_type}`}
  </span>

  <a href={`/producto/${product.slug}`} class="relative h-64 overflow-hidden block bg-cream-100 flex-shrink-0">
    {product.primary_image_url ? (
      <>
        <div class="absolute inset-0 z-0 overflow-hidden">
          <img 
            src={product.primary_image_url} 
            alt="" 
            class="w-full h-full object-cover blur-2xl opacity-50 scale-125 transform group-hover:scale-150 transition-transform duration-700"
            aria-hidden="true"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-cream-100/40 backdrop-blur-md"></div>
        </div>

        <div class="relative z-10 w-full h-full flex items-center justify-center p-3">
          <img 
            src={product.primary_image_url} 
            alt={product.name}
            width="400"
            height="256"
            loading="lazy"
            decoding="async"
            class="max-w-full max-h-full object-contain rounded-md shadow-md transform group-hover:scale-105 transition-transform duration-500 bg-white/50"
          />
        </div>
      </>
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center text-brand-muted relative z-10">
        <span class="text-3xl mb-2">🖼️</span>
        <span class="text-sm font-medium">Sin imagen</span>
      </div>
    )}
  </a>

  <div class="p-5 flex flex-col flex-1 relative z-20 bg-white">
    <div class="mb-2">
      <span class="text-xs font-semibold text-gold-dark uppercase tracking-wider">
        {product.categories?.name || 'Varios'}
      </span>
    </div>
    
    <a href={`/producto/${product.slug}`} class="block mb-2">
      <h3 class="font-serif text-xl font-bold text-brand-text leading-tight group-hover:text-gold-dark transition-colors line-clamp-2">
        {product.name}
      </h3>
    </a>
    
    <p class="text-sm text-brand-muted line-clamp-2 mb-4 flex-1">
      {product.description}
    </p>

    <div class="mt-auto pt-4 border-t border-cream-200">
      <div class="flex justify-between items-end mb-4">
        <div>
          <span class="text-sm text-gold-dark font-bold">{product.currency}</span>
          <span class="text-2xl font-bold text-brand-text ml-1">{product.price.toFixed(2)}</span>
        </div>
        {unitPrice && (
          <div class="text-right">
            <span class="block text-xs text-brand-muted">Ref. Unidad</span>
            <span class="text-sm font-semibold text-brand-muted">{product.currency} {unitPrice}</span>
          </div>
        )}
      </div>

      <a 
        href={`/producto/${product.slug}`} 
        class="w-full block text-center bg-gold text-white font-semibold py-2.5 rounded-lg hover:bg-gold-dark transition-colors shadow-sm"
      >
        Ver Detalles →
      </a>
    </div>
  </div>
</article>