---
import AdminLayout from '@/ui/layouts/AdminLayout.astro';
import Button from '@/ui/components/Button.astro';
import { createSupabaseServerClient } from '@/lib/supabase-server';
import type { Category } from '@/core/types/database';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data, error } = await supabase.from('categories').select('*').order('name');
const categories = (data as Category[]) || [];
---

<AdminLayout title="Categorías">
  <div class="mb-8 flex justify-between items-center pb-4 border-b border-brand-border">
    <div>
      <h1 class="text-3xl font-bold text-gold-dark">Categorías</h1>
      <p class="text-brand-muted mt-1">Organiza la taxonomía de tus productos.</p>
    </div>
    <Button href="/admin/categorias/nuevo" variant="primary" size="sm">+ Nueva Categoría</Button>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-brand-border overflow-hidden">
    {error && <div class="p-4 bg-red-50 text-red-600">Error: {error.message}</div>}
    
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-cream-100 text-brand-muted text-sm uppercase tracking-wider">
            <th class="p-4 font-medium">Nombre</th>
            <th class="p-4 font-medium">Slug (URL)</th>
            <th class="p-4 font-medium">Descripción</th>
            <th class="p-4 font-medium text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-brand-border">
          {categories.length === 0 ? (
            <tr><td colspan="4" class="p-8 text-center text-brand-muted italic">No hay categorías registradas.</td></tr>
          ) : (
            categories.map((cat) => (
              <tr class="hover:bg-cream-50 transition-colors">
                <td class="p-4 font-semibold text-brand-text">{cat.name}</td>
                <td class="p-4 text-sm text-brand-muted font-mono">{cat.slug}</td>
                <td class="p-4 text-sm text-brand-muted truncate max-w-xs">{cat.description || '-'}</td>
                <td class="p-4 text-right">
                  <a href={`/admin/categorias/editar/${cat.id}`} class="text-gold hover:text-gold-dark font-medium text-sm">Editar</a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>