import React, { useState, useEffect } from 'react';

interface ImageGalleryProps {
  productName: string;
  images: { url: string | null; is_primary: boolean }[];
}

export const ImageGallery: React.FC<ImageGalleryProps> = ({ productName, images }) => {
  const validImages = images.filter(img => img.url !== null) as { url: string; is_primary: boolean }[];
  
  const [mainImage, setMainImage] = useState<string>(
    validImages.find(i => i.is_primary)?.url || validImages[0]?.url || ''
  );

  useEffect(() => {
    setMainImage(validImages.find(i => i.is_primary)?.url || validImages[0]?.url || '');
  }, [images]);

  if (validImages.length === 0) {
    return (
      <div className="aspect-square bg-cream-100 rounded-2xl flex items-center justify-center border border-brand-border">
        <span className="text-brand-muted text-lg">Sin imágenes disponibles</span>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      {/* CONTENEDOR PRINCIPAL */}
      <div className="relative aspect-square w-full bg-cream-200 rounded-2xl overflow-hidden border border-brand-border shadow-sm group">
        
        {/* FOCOS DE LUZ ESTÁTICOS (Le dan vida y profundidad al cristal sin imitar la foto) */}
        <div className="absolute -top-10 -left-10 w-3/4 h-3/4 bg-white rounded-full blur-3xl opacity-90 pointer-events-none" />
        <div className="absolute -bottom-10 -right-10 w-3/4 h-3/4 bg-gold-light/30 rounded-full blur-3xl opacity-60 pointer-events-none" />

        {/* CRISTAL ESMERILADO (Frosted Glass real, claro y sutil) */}
        <div className="absolute inset-0 z-0 bg-gold-light/30 backdrop-blur-xl border border-white/60 pointer-events-none" />

        {/* IMAGEN PRINCIPAL (Aislada, completa y sin recortes) */}
        <div className="absolute inset-0 z-10 p-6 flex items-center justify-center">
          <img 
            key={mainImage}
            src={mainImage} 
            alt={productName}
            loading="eager"
            decoding="sync"
            style={{ 
              width: '100%', 
              height: '100%', 
              objectFit: 'contain' 
            }}
            className="drop-shadow-xl select-none"
          />
        </div>
      </div>

      {/* GALERÍA DE MINIATURAS */}
      {validImages.length > 1 && (
        <div className="grid grid-cols-4 gap-4">
          {validImages.map((img, idx) => (
            <button
              key={idx}
              type="button"
              onClick={() => setMainImage(img.url)}
              className={`relative aspect-square w-full bg-cream-200 rounded-xl overflow-hidden border-2 transition-all focus:outline-none ${
                mainImage === img.url 
                  ? 'border-gold shadow-md scale-95 opacity-100' 
                  : 'border-brand-border hover:border-gold-light opacity-80 hover:opacity-100'
              }`}
            >
              {/* FOCOS DE LUZ MINIATURAS */}
              <div className="absolute -top-4 -left-4 w-full h-full bg-white rounded-full blur-xl opacity-90 pointer-events-none" />
              <div className="absolute -bottom-4 -right-4 w-full h-full bg-gold-light/30 rounded-full blur-xl opacity-60 pointer-events-none" />

              {/* CRISTAL MINIATURA */}
              <div className="absolute inset-0 z-0 bg-white/30 backdrop-blur-md border border-white/50 pointer-events-none" />
              
              {/* IMAGEN MINIATURA */}
              <div className="absolute inset-0 z-10 p-2 flex items-center justify-center">
                <img 
                  src={img.url} 
                  alt={`Vista ${idx + 1}`} 
                  loading="lazy"
                  style={{ width: '100%', height: '100%', objectFit: 'contain' }} 
                  className="drop-shadow-sm select-none"
                />
              </div>
            </button>
          ))}
        </div>
      )}
    </div>
  );
};
